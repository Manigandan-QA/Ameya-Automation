# Execution mode: local | browserstack
EXEC_MODE=local

# Target environment
TEST_ENV=staging

# Web portal
WEB_BASE_URL=https://app.ameyahealth.com

# Registered test account email
TEST_USER_EMAIL=your-work-email@yourcompany.com

# ─── IMAP — Corporate Outlook / Office 365 ───────────────────────────────────
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=your-work-email@yourcompany.com
IMAP_PASSWORD=your-outlook-password

# Sender the OTP email arrives from
IMAP_OTP_FROM=noreply@ameyahealth.com

# How long (ms) to wait for OTP email
IMAP_OTP_TIMEOUT_MS=30000
# ─────────────────────────────────────────────────────────────────────────────

# BrowserStack (not needed for local runs)
BROWSERSTACK_USERNAME=your_bs_username
BROWSERSTACK_ACCESS_KEY=your_bs_access_key
BROWSERSTACK_APP_URL=bs://UPLOAD_HASH_HERE

# Local Appium
LOCAL_PLATFORM=Android
LOCAL_APP_PATH=./builds/ameya-patient-portal.apk
LOCAL_APPIUM_HOST=localhost
LOCAL_APPIUM_PORT=4723

CI=false
DEBUG=false
