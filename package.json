{
  "name": "ameya-automation",
  "version": "1.0.0",
  "description": "Enterprise test automation framework — Ameya Patient Portal (Web + Mobile)",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test:web:p0:local": "EXEC_MODE=local npx cucumber-js --profile web --tags \"@P0 and @web\"",
    "test:web:p1:local": "EXEC_MODE=local npx cucumber-js --profile web --tags \"@P1 and @web\"",
    "test:web:p2:local": "EXEC_MODE=local npx cucumber-js --profile web --tags \"@P2 and @web\"",
    "test:mobile:p0:local": "EXEC_MODE=local npx cucumber-js --profile mobile --tags \"@P0 and @mobile\"",
    "test:mobile:p1:local": "EXEC_MODE=local npx cucumber-js --profile mobile --tags \"@P1 and @mobile\"",
    "test:web:p0:bs": "EXEC_MODE=browserstack npx cucumber-js --profile web --tags \"@P0 and @web\"",
    "test:web:p1:bs": "EXEC_MODE=browserstack npx cucumber-js --profile web --tags \"@P1 and @web\"",
    "test:mobile:p0:bs": "EXEC_MODE=browserstack npx cucumber-js --profile mobile --tags \"@P0 and @mobile\"",
    "test:mobile:p1:bs": "EXEC_MODE=browserstack npx cucumber-js --profile mobile --tags \"@P1 and @mobile\"",
    "save-session": "node scripts/save-session.js",
    "test:smoke": "EXEC_MODE=local npx cucumber-js --profile web --tags \"@smoke\"",
    "report:html": "node scripts/generate-report.js",
    "report:allure:generate": "allure generate reports/allure-results -o reports/allure-report --clean",
    "report:allure:open": "allure open reports/allure-report",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "imapflow": "^1.0.164",
    "mailparser": "^3.7.1"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.4",
    "@cucumber/cucumber": "^10.8.0",
    "@cucumber/messages": "^24.1.0",
    "@faker-js/faker": "^8.4.0",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "@wdio/cli": "^8.38.0",
    "allure-commandline": "^2.29.0",
    "dotenv": "^16.4.0",
    "multiple-cucumber-html-reporter": "^3.5.0",
    "playwright": "^1.44.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "webdriverio": "^8.38.0"
  }
}
